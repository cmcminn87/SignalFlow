function getEP(ns,fid,tid){const f=ns.find(n=>n.id===fid),t=ns.find(n=>n.id===tid);if(!f||!t)return{fx:0,fy:0,tx:0,ty:0};const fc={x:f.x+f.w/2,y:f.y+f.h/2},tc={x:t.x+t.w/2,y:t.y+t.h/2},ang=Math.atan2(tc.y-fc.y,tc.x-fc.x),ex=(n,cx,cy,a)=>{const hw=n.w/2,hh=n.h/2,ta=Math.atan2(hh,hw),aa=Math.abs(a);if(aa<ta||aa>Math.PI-ta){const s=Math.sign(Math.cos(a));return{x:cx+s*hw,y:cy+s*hw*Math.tan(a)}}const s=Math.sign(Math.sin(a));return{x:cx+s*hh/Math.tan(a),y:cy+s*hh}},fp=ex(f,fc.x,fc.y,ang),tp=ex(t,tc.x,tc.y,ang+Math.PI);return{fx:fp.x,fy:fp.y,tx:tp.x,ty:tp.y}}

