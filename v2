function buildSVG(){const ns=S.nodes,cs=S.conns;let mnX=1e9,mnY=1e9,mxX=-1e9,mxY=-1e9;ns.forEach(n=>{mnX=Math.min(mnX,n.x);mnY=Math.min(mnY,n.y);mxX=Math.max(mxX,n.x+n.w);mxY=Math.max(mxY,n.y+n.h)});if(!ns.length){mnX=0;mnY=0;mxX=800;mxY=600}const p=60;mnX-=p;mnY-=p;mxX+=p;mxY+=p;const cw=mxX-mnX,ch=mxY-mnY;let s=`<svg xmlns="http://www.w3.org/2000/svg" width="${cw}" height="${ch}" viewBox="${mnX} ${mnY} ${cw} ${ch}"><rect x="${mnX}" y="${mnY}" width="${cw}" height="${ch}" fill="#1a1a2e"/><text x="${mnX+cw/2}" y="${mnY+28}" text-anchor="middle" fill="#eee" font-size="18" font-weight="bold" font-family="Arial">${esc(S.curName)}</text>`;Object.entries(CC).forEach(([k,v],i)=>{const lx=mnX+20,ly=mnY+50+i*18;s+=`<line x1="${lx}" y1="${ly}" x2="${lx+16}" y2="${ly}" stroke="${v}" stroke-width="2.5"/><text x="${lx+22}" y="${ly+4}" fill="#aaa" font-size="10" font-family="Arial">${k}</text>`});cs.forEach(c=>{const f=ns.find(n=>n.id===c.from),t=ns.find(n=>n.id===c.to);if(!f||!t)return;const{fx,fy,tx,ty}=getEP(ns,c.from,c.to);const mx=(fx+tx)/2,my=(fy+ty)/2,col=CC[c.type]||CC.Other;s+=`<line x1="${fx}" y1="${fy}" x2="${tx}" y2="${ty}" stroke="${col}" stroke-width="2" opacity="0.7"/><circle cx="${tx}" cy="${ty}" r="3" fill="${col}"/>`;if(c.label){const bw=c.label.length*6.4+12;s+=`<rect x="${mx-bw/2}" y="${my-9}" width="${bw}" height="18" rx="3" fill="#1a1a2e" opacity="0.85"/><text x="${mx}" y="${my+4}" text-anchor="middle" fill="#aaa" font-size="9" font-family="monospace">${esc(c.label)}</text>`}});ns.forEach(n=>{s+=`<rect x="${n.x}" y="${n.y}" width="${n.w}" height="${n.h}" rx="6" fill="${n.color}" stroke="rgba(255,255,255,0.15)"/>`;n.label.split("\n").forEach((ln,li,ar)=>{const ty=n.y+n.h/2+(li-(ar.length-1)/2)*14;s+=`<text x="${n.x+n.w/2}" y="${ty}" text-anchor="middle" dominant-baseline="central" fill="#fff" font-size="11" font-weight="bold" font-family="Arial">${esc(ln)}</text>`})});return s+`</svg>`}
function dlFile(content,name,type){const b=new Blob([content],{type});const u=URL.createObjectURL(b);const a=document.createElement("a");a.href=u;a.download=name;document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(u)}
window.exportSVG=()=>dlFile(buildSVG(),S.curName.replace(/[^a-zA-Z0-9]/g,"_")+".svg","image/svg+xml");
window.exportJSON=()=>dlFile(JSON.stringify({name:S.curName,nodes:S.nodes,conns:S.conns,exportedAt:new Date().toISOString()},null,2),S.curName.replace(/[^a-zA-Z0-9]/g,"_")+".json","application/json");
window.importJSON=el=>{if(!el.files[0])return;const r=new FileReader();r.onload=e=>{try{const d=JSON.parse(e.target.result);if(d.nodes&&d.conns){S.nodes=d.nodes;S.conns=d.conns;S.curName=d.name||"Imported";S.screen="editor";S.zoom=.85;S.panX=0;S.panY=0;S.mode="move";S.sel=null;S.connSt=null;render()}}catch(err){alert("Invalid JSON")}};r.readAsText(el.files[0]);el.value=""};

// ========== GEAR ADD ==========
window.addGear=function(catIdx,itemIdx){const g=GEAR[catIdx];const it=g.items[itemIdx];const label=it.id?`${it.label}\n${it.id}`:it.label;const color=CAT_COLORS[g.cat]||"#555";const lines=label.split("\n"),ml=Math.max(...lines.map(x=>x.length));const cx=(-S.panX+400)/S.zoom,cy=(-S.panY+300)/S.zoom;S.nodes.push({id:uid(),label,x:cx-60,y:cy-20,w:Math.max(120,ml*9+20),h:Math.max(40,lines.length*18+16),color});renderSVGOnly()};

// ========== ACTIONS ==========
window.openTemplate=i=>{const t=i===-1?{name:"Blank Canvas",nodes:[],conns:[]}:TEMPLATES[i];S.nodes=clone(t.nodes);S.conns=clone(t.conns);S.curName=t.name;S.screen="editor";S.zoom=.85;S.panX=0;S.panY=0;S.mode="move";S.sel=null;S.connSt=null;S.gearOpen=false;render()};
window.openSaved=i=>{const s=S.saved[i];S.nodes=clone(s.nodes);S.conns=clone(s.conns);S.curName=s.name;S.screen="editor";S.zoom=.85;S.panX=0;S.panY=0;S.mode="move";S.sel=null;S.connSt=null;S.gearOpen=false;render()};
window.delSaved=i=>{event.stopPropagation();S.saved.splice(i,1);persist();render()};
window.goHome=()=>{S.screen="home";S.modal=null;render()};
window.setMode=m=>{S.mode=m;S.connSt=null;render()};
window.toggleGear=()=>{S.gearOpen=!S.gearOpen;render()};
window.setGearCat=c=>{S.gearCat=c;renderGear()};
window.setGearFilter=v=>{S.gearFilter=v;renderGear()};
window.showSave=()=>{S.fd={name:S.curName};S.modal="save";render();renderModal()};
window.startEdit=id=>{const n=S.nodes.find(n=>n.id===id);S.fd={id,label:n.label.replace(/\n/g,"\\n")};S.modal="edit";render();renderModal()};

window.doAddNode=()=>{const v=document.getElementById("m-label")?.value;if(!v?.trim())return;const l=v.replace(/\\n/g,"\n"),lines=l.split("\n"),ml=Math.max(...lines.map(x=>x.length));S.nodes.push({id:uid(),label:l,x:(S.fd.x||400)-60,y:(S.fd.y||300)-20,w:Math.max(120,ml*9+20),h:Math.max(40,lines.length*18+16),color:S.fd.color||COLORS[0]});S.modal=null;render()};
window.doAddConn=()=>{const v=document.getElementById("m-clabel")?.value||"";S.conns.push({id:cuid(),from:S.fd.from,to:S.fd.to,label:v,type:S.fd.type||"SDI"});S.modal=null;render()};
window.doSaveEdit=()=>{const v=document.getElementById("m-elabel")?.value||"";const l=v.replace(/\\n/g,"\n"),lines=l.split("\n"),ml=Math.max(...lines.map(x=>x.length));const n=S.nodes.find(n=>n.id===S.fd.id);if(n){n.label=l;n.w=Math.max(120,ml*9+20);n.h=Math.max(40,lines.length*18+16)}S.modal=null;render()};
window.doSave=()=>{const v=document.getElementById("m-sname")?.value?.trim();if(!v)return;S.saved.push({name:v,nodes:clone(S.nodes),conns:clone(S.conns),ts:Date.now()});S.curName=v;persist();S.modal=null;render()};
window.setFDColor=c=>{S.fd.color=c;renderModal()};
window.setFDType=t=>{S.fd.type=t;renderModal()};
window.setEditColor=c=>{const n=S.nodes.find(n=>n.id===S.fd.id);if(n)n.color=c;renderModal();renderSVGOnly()};

// ========== RENDER ==========
function render(){const app=document.getElementById("app");if(S.screen==="home")renderHome(app);else renderEditor(app)}

function renderHome(app){
  let h=`<div class="home"><div class="home-inner"><h1 style="font-size:24px;margin-bottom:4px">Signal Flow Editor</h1><p style="color:#888;font-size:14px;margin-bottom:20px">Select a template or open a saved flow. Chicago gear catalog built in.</p>`;
  h+=`<div style="margin-bottom:20px"><button onclick="document.getElementById('imp').click()" style="background:#4a6fa5;color:#fff;border:none;border-radius:6px;padding:8px 14px;cursor:pointer;font-size:13px;font-weight:bold">📂 Import JSON</button><input type="file" id="imp" accept=".json" style="display:none" onchange="importJSON(this)"></div>`;
  if(S.saved.length){h+=`<h2 style="font-size:16px;margin-bottom:10px;color:#7aafff">Saved Flows</h2><div class="grid">`;S.saved.forEach((s,i)=>{h+=`<div class="card" onclick="openSaved(${i})"><div style="font-weight:bold;font-size:14px;margin-bottom:3px">${esc(s.name)}</div><div style="color:#888;font-size:12px">${s.nodes.length} nodes · ${s.conns.length} conns</div><div style="color:#556;font-size:11px;margin-top:4px">${new Date(s.ts).toLocaleString()}</div><button onclick="delSaved(${i})" style="position:absolute;top:8px;right:8px;background:0;border:0;color:#664;cursor:pointer;font-size:16px">×</button></div>`});h+=`</div>`}
  h+=`<h2 style="font-size:16px;margin-bottom:10px;color:#aaa">Templates</h2><div class="grid">`;
  h+=`<div class="card blank-card" onclick="openTemplate(-1)"><div><div style="font-size:28px;margin-bottom:4px">➕</div><div style="font-weight:bold;font-size:14px">Blank Canvas</div></div></div>`;
  TEMPLATES.forEach((t,i)=>{h+=`<div class="card" onclick="openTemplate(${i})"><div style="font-weight:bold;font-size:14px;margin-bottom:3px">${esc(t.name)}</div><div style="color:#888;font-size:12px">${esc(t.desc)}</div><div style="color:#556;font-size:11px;margin-top:5px">${t.nodes.length} nodes · ${t.conns.length} conns</div></div>`});
  h+=`</div></div></div>`;app.innerHTML=h;
}

function renderEditor(app){
  const gw=S.gearOpen?280:0;
  let h=`<div style="display:flex;height:100vh;width:100%">`;
  // Gear panel
  h+=`<div id="gearpanel" style="width:${gw}px;overflow:hidden;background:#12192a;border-right:1px solid #333;flex-shrink:0;display:flex;flex-direction:column;height:100vh;transition:width .2s">`;
  if(S.gearOpen){
    h+=`<div style="padding:10px 12px;border-bottom:1px solid #333;display:flex;justify-content:space-between;align-items:center"><span style="font-weight:bold;font-size:13px">Chicago Gear</span><button onclick="toggleGear()" style="background:0;border:0;color:#888;cursor:pointer;font-size:16px">×</button></div>`;
    h+=`<div style="padding:8px 10px"><input id="gear-search" value="${esc(S.gearFilter)}" oninput="setGearFilter(this.value)" placeholder="Search gear..." class="minput" style="font-size:12px;margin-bottom:6px">`;
    h+=`<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:4px">`;
    ["All","Video","Audio","Lighting","Misc"].forEach(c=>{h+=`<button onclick="setGearCat('${c}')" style="padding:2px 8px;border-radius:4px;font-size:10px;cursor:pointer;background:${S.gearCat===c?(CAT_COLORS[c]||"#4a6fa5"):"transparent"};color:${S.gearCat===c?"#fff":(CAT_COLORS[c]||"#aaa")};border:1px solid ${CAT_COLORS[c]||"#445"}">${c}</button>`});
    h+=`</div></div><div id="gearlist" style="flex:1;overflow-y:auto;padding:0 10px 10px"></div>`;
  }
  h+=`</div>`;
  // Main area
  h+=`<div style="flex:1;display:flex;flex-direction:column;min-width:0">`;
  // Toolbar
  h+=`<div style="padding:5px 10px;background:#16213e;display:flex;justify-content:space-between;align-items:center;gap:5px;flex-wrap:wrap">`;
  h+=`<div style="display:flex;align-items:center;gap:6px"><button onclick="goHome()" style="background:0;border:1px solid #445;border-radius:6px;padding:4px 9px;cursor:pointer;color:#aaa;font-size:12px">←</button>`;
  h+=`<button onclick="toggleGear()" style="background:${S.gearOpen?"#2E7D32":"#253554"};border:1px solid #445;border-radius:6px;padding:5px 9px;cursor:pointer;color:#eee;font-size:11px">🎛️ Gear</button>`;
  h+=`<strong style="font-size:12px;color:#eee">${esc(S.curName)}</strong></div>`;
  h+=`<div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap">`;
  ["move","addNode","addConn","delete"].forEach(m=>{const lb={move:"✋ Move",addNode:"➕ Add",addConn:"🔗 Link","delete":"🗑️ Del"};h+=`<button onclick="setMode('${m}')" style="background:${S.mode===m?"#4a6fa5":"#253554"};color:#eee;border:${S.mode===m?"2px solid #7aafff":"1px solid #445"};border-radius:6px;padding:5px 9px;cursor:pointer;font-size:11px">${lb[m]}</button>`});
  h+=`<div style="width:1px;height:20px;background:#445"></div>`;
  h+=`<button onclick="showSave()" style="background:#4a6fa5;color:#fff;border:none;border-radius:6px;padding:5px 10px;cursor:pointer;font-size:11px;font-weight:bold">💾</button>`;
  h+=`<button onclick="exportSVG()" style="background:#2E7D32;color:#fff;border:none;border-radius:6px;padding:5px 10px;cursor:pointer;font-size:11px;font-weight:bold">SVG</button>`;
  h+=`<button onclick="exportJSON()" style="background:#1565C0;color:#fff;border:none;border-radius:6px;padding:5px 10px;cursor:pointer;font-size:11px;font-weight:bold">JSON</button>`;
  h+=`</div></div>`;
  // Hint
  const hbg=S.mode==="delete"?"#3a1515":S.mode==="addNode"?"#153020":S.mode==="addConn"?"#152535":"#111825";
  const hints={move:"Drag nodes · Scroll zoom · Drag bg to pan · Dbl-click edit · Use Gear panel to add equipment",addNode:"Click canvas to place a custom node, or use the Gear panel",addConn:S.connSt?"Click destination node":"Click source, then destination","delete":"Click node or connection label to delete"};
  h+=`<div style="padding:3px 10px;background:${hbg};color:#777;font-size:10px">${hints[S.mode]}</div>`;
  // SVG
  h+=`<svg id="svg" width="100%" style="flex:1;cursor:${S.mode==="delete"?"crosshair":S.mode==="addNode"?"cell":S.mode==="addConn"?"pointer":"grab"}"></svg>`;
  h+=`</div></div>`;
  app.innerHTML=h;
  renderSVGOnly();
  renderGear();
  attachEvents();
}

function renderGear(){
  const list=document.getElementById("gearlist");if(!list)return;
  const q=S.gearFilter.toLowerCase();
  let h="";let found=false;
  GEAR.forEach((g,gi)=>{
    if(S.gearCat!=="All"&&g.cat!==S.gearCat)return;
    const filtered=g.items.filter(it=>!q||it.model.toLowerCase().includes(q)||it.label.toLowerCase().includes(q)||(it.id||"").toLowerCase().includes(q));
    if(!filtered.length)return;
    found=true;
    h+=`<div style="font-size:10px;color:#888;font-weight:bold;margin:8px 0 4px;text-transform:uppercase">${g.cat}${g.sub?" — "+g.sub:""}</div>`;
    filtered.forEach(it=>{const ii=g.items.indexOf(it);h+=`<div onclick="addGear(${gi},${ii})" style="padding:6px 8px;background:#1a2235;border-radius:6px;margin-bottom:3px;cursor:pointer;border-left:3px solid ${CAT_COLORS[g.cat]||"#555"}" onmouseover="this.style.background='#253554'" onmouseout="this.style.background='#1a2235'"><div style="font-size:12px;font-weight:bold;color:#ddd">${esc(it.model)}</div><div style="font-size:10px;color:#777;display:flex;justify-content:space-between"><span>${esc(it.id||"")}</span><span>×${it.qty}</span></div></div>`});
  });
  if(!found)h=`<div style="color:#556;font-size:12px;margin-top:20px;text-align:center">No gear matches</div>`;
  list.innerHTML=h;
}

function renderSVGOnly(){
  const svg=document.getElementById("svg");if(!svg)return;
  const ns=S.nodes,cs=S.conns;
  let s=`<rect data-bg="1" width="100%" height="100%" fill="#1a1a2e"/><g transform="translate(${S.panX},${S.panY}) scale(${S.zoom})">`;
  cs.forEach(c=>{const f=ns.find(n=>n.id===c.from),t=ns.find(n=>n.id===c.to);if(!f||!t)return;const{fx,fy,tx,ty}=getEP(ns,c.from,c.to);const mx=(fx+tx)/2,my=(fy+ty)/2,col=CC[c.type]||CC.Other;
    s+=`<line x1="${fx}" y1="${fy}" x2="${tx}" y2="${ty}" stroke="${col}" stroke-width="2" opacity="0.7"/><circle cx="${tx}" cy="${ty}" r="3" fill="${col}"/>`;
    if(c.label){const bw=c.label.length*6.4+12;s+=`<g transform="translate(${mx},${my})" data-conn="${c.id}" style="cursor:${S.mode==="delete"?"pointer":"default"}"><rect x="${-bw/2}" y="-9" width="${bw}" height="18" rx="3" fill="${S.mode==="delete"?"#3a1515":"#1a1a2e"}" opacity="0.9" stroke="${S.mode==="delete"?"#a33":"transparent"}"/><text text-anchor="middle" dy="4" fill="${S.mode==="delete"?"#f88":"#aaa"}" font-size="9" font-family="monospace" pointer-events="none">${esc(c.label)}</text></g>`}});
  if(S.mode==="addConn"&&S.connSt){const n=ns.find(n=>n.id===S.connSt);if(n)s+=`<line x1="${n.x+n.w/2}" y1="${n.y+n.h/2}" x2="${S.mX}" y2="${S.mY}" stroke="#7aafff" stroke-width="2" stroke-dasharray="6 4" opacity="0.6" pointer-events="none"/>`}
  ns.forEach(n=>{const sel=S.sel===n.id,cs2=S.connSt===n.id,del=S.mode==="delete";const stroke=sel?"#fff":cs2?"#7aafff":del?"#f44":"rgba(255,255,255,0.15)";const sw=sel||cs2?2.5:del?2:1;
    s+=`<g data-node="${n.id}" transform="translate(${n.x},${n.y})" style="cursor:${del?"pointer":S.mode==="addConn"?"pointer":"move"}"><rect width="${n.w}" height="${n.h}" rx="6" fill="${n.color}" stroke="${stroke}" stroke-width="${sw}" ${sel?'filter="url(#glow)"':""}/>`;
    n.label.split("\n").forEach((ln,li,ar)=>{const ty=n.h/2+(li-(ar.length-1)/2)*14;s+=`<text x="${n.w/2}" y="${ty}" text-anchor="middle" dominant-baseline="central" fill="#fff" font-size="11" font-weight="bold" font-family="Arial" pointer-events="none">${esc(ln)}</text>`});
    s+=`</g>`});
  s+=`<defs><filter id="glow"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs></g>`;
  s+=`<g transform="translate(16,12)">`;Object.entries(CC).forEach(([k,v],i)=>{s+=`<g transform="translate(0,${i*16})"><line x1="0" y1="0" x2="16" y2="0" stroke="${v}" stroke-width="2.5"/><text x="20" y="4" fill="#aaa" font-size="9">${k}</text></g>`});s+=`</g>`;
  svg.innerHTML=s;
}

function svgPt(cx,cy){const svg=document.getElementById("svg");if(!svg)return{x:cx,y:cy};const r=svg.getBoundingClientRect();return{x:(cx-r.left-S.panX)/S.zoom,y:(cy-r.top-S.panY)/S.zoom}}

function attachEvents(){
  const svg=document.getElementById("svg");if(!svg)return;
  svg.onpointerdown=e=>{
    const nodeEl=e.target.closest("[data-node]"),connEl=e.target.closest("[data-conn]");
    if(connEl&&S.mode==="delete"){e.stopPropagation();S.conns=S.conns.filter(c=>c.id!==connEl.dataset.conn);renderSVGOnly();return}
    if(nodeEl){e.stopPropagation();const id=nodeEl.dataset.node;
      if(S.mode==="delete"){S.nodes=S.nodes.filter(n=>n.id!==id);S.conns=S.conns.filter(c=>c.from!==id&&c.to!==id);S.sel=null;render();return}
      if(S.mode==="addConn"){if(!S.connSt){S.connSt=id;renderSVGOnly()}else if(S.connSt!==id){S.fd={from:S.connSt,to:id,label:"",type:"SDI"};S.connSt=null;S.modal="conn";render();renderModal()}return}
      const pt=svgPt(e.clientX,e.clientY);const n=S.nodes.find(n=>n.id===id);S.drag=id;S.sel=id;S.offX=pt.x-n.x;S.offY=pt.y-n.y;renderSVGOnly();return}
    if(e.target===svg||e.target.dataset.bg){S.sel=null;
      if(S.mode==="addNode"){const pt=svgPt(e.clientX,e.clientY);S.fd={x:pt.x,y:pt.y,label:"",color:COLORS[0]};S.modal="addNode";render();renderModal();return}
      if(S.mode==="addConn"){S.connSt=null;renderSVGOnly();return}
      S.panning=true;S.psX=e.clientX-S.panX;S.psY=e.clientY-S.panY;renderSVGOnly()}
  };
  svg.onpointermove=e=>{const pt=svgPt(e.clientX,e.clientY);S.mX=pt.x;S.mY=pt.y;
    if(S.panning){S.panX=e.clientX-S.psX;S.panY=e.clientY-S.psY;renderSVGOnly();return}
    if(S.drag){const n=S.nodes.find(n=>n.id===S.drag);if(n){n.x=pt.x-S.offX;n.y=pt.y-S.offY;renderSVGOnly()}return}
    if(S.mode==="addConn"&&S.connSt)renderSVGOnly()};
  svg.onpointerup=()=>{S.drag=null;S.panning=false};
  svg.ondblclick=e=>{const ne=e.target.closest("[data-node]");if(ne&&S.mode==="move")startEdit(ne.dataset.node)};
  svg.addEventListener("wheel",e=>{e.preventDefault();S.zoom=Math.min(2,Math.max(.3,S.zoom-e.deltaY*.001));renderSVGOnly()},{passive:false});
}

// ========== MODALS ==========
function renderModal(){
  let old=document.getElementById("modal-ov");if(old)old.remove();
  if(!S.modal)return;
  const div=document.createElement("div");div.id="modal-ov";div.className="overlay";
  div.onclick=e=>{if(e.target===div){S.modal=null;render()}};
  let h=`<div class="modal" onclick="event.stopPropagation()">`;
  if(S.modal==="addNode"){
    h+=`<h3>Add Custom Node</h3><label>Label (\\n for line breaks)</label><input id="m-label" class="minput" value="${esc(S.fd.label||"")}" placeholder="e.g. NEW CAMERA">`;
    h+=`<label>Color</label><div class="color-row">`;COLORS.forEach(c=>{h+=`<div class="cswatch ${S.fd.color===c?"sel":""}" style="background:${c}" onclick="setFDColor('${c}')"></div>`});
    h+=`</div><div class="mactions"><button class="btn-c" onclick="S.modal=null;render()">Cancel</button><button class="btn-p" onclick="doAddNode()">Add</button></div>`;
  }else if(S.modal==="conn"){
    const fn=S.nodes.find(n=>n.id===S.fd.from),tn=S.nodes.find(n=>n.id===S.fd.to);
    h+=`<h3>New Connection</h3><p style="font-size:11px;color:#aaa;margin-bottom:8px">${fn?esc(fn.label.replace(/\n/g," ")):""} → ${tn?esc(tn.label.replace(/\n/g," ")):""}</p>`;
    h+=`<label>Label</label><input id="m-clabel" class="minput" value="" placeholder="e.g. SDI OUT 5">`;
    h+=`<label>Type</label><div class="type-row">`;Object.entries(CC).forEach(([k,v])=>{h+=`<button class="tbtn" style="background:${S.fd.type===k?v:"transparent"};color:${S.fd.type===k?"#fff":v};border:1.5px solid ${v};font-weight:${S.fd.type===k?"bold":"normal"}" onclick="setFDType('${k}')">${k}</button>`});
    h+=`</div><div class="mactions"><button class="btn-c" onclick="S.modal=null;render()">Cancel</button><button class="btn-p" onclick="doAddConn()">Add</button></div>`;
  }else if(S.modal==="edit"){
    const cur=S.nodes.find(n=>n.id===S.fd.id)?.color;
    h+=`<h3>Edit Node</h3><label>Label</label><input id="m-elabel" class="minput" value="${esc(S.fd.label||"")}">`;
    h+=`<label>Color</label><div class="color-row">`;COLORS.forEach(c=>{h+=`<div class="cswatch ${cur===c?"sel":""}" style="background:${c}" onclick="setEditColor('${c}')"></div>`});
    h+=`</div><div class="mactions"><button class="btn-c" onclick="S.modal=null;render()">Cancel</button><button class="btn-p" onclick="doSaveEdit()">Save</button></div>`;
  }else if(S.modal==="save"){
    h+=`<h3>Save Flow</h3><label>Name</label><input id="m-sname" class="minput" value="${esc(S.fd.name||"")}">`;
    h+=`<div class="mactions"><button class="btn-c" onclick="S.modal=null;render()">Cancel</button><button class="btn-p" onclick="doSave()">Save</button></div>`;
  }
  h+=`</div>`;div.innerHTML=h;document.body.appendChild(div);
  setTimeout(()=>{const inp=div.querySelector("input");if(inp){inp.focus();inp.setSelectionRange(inp.value.length,inp.value.length);inp.onkeydown=e=>{if(e.key==="Enter"){if(S.modal==="addNode")doAddNode();else if(S.modal==="conn")doAddConn();else if(S.modal==="edit")doSaveEdit();else if(S.modal==="save")doSave()}}}},50);
}

// Boot
render();
</script>
</body>
</html>
