*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;overflow:hidden;height:100vh}
.home{min-height:100vh;overflow-y:auto;padding:24px}
.home-inner{max-width:960px;margin:0 auto}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:28px}
.card{background:#16213e;border:1px solid #335;border-radius:10px;padding:14px;cursor:pointer;transition:border .15s;position:relative}
.card:hover{border-color:#7aafff}
.blank-card{border:2px dashed #445;display:flex;align-items:center;justify-content:center;min-height:80px;text-align:center}
.blank-card:hover{border-color:#7aafff}
.overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:999}
.modal{background:#1e2a3a;border-radius:12px;padding:20px;min-width:300px;max-width:420px;color:#eee;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.modal h3{margin:0 0 12px;font-size:15px}
.modal label{font-size:11px;color:#aaa}
.minput{width:100%;padding:7px 10px;border-radius:6px;border:1px solid #445;background:#16213e;color:#eee;font-size:13px;box-sizing:border-box;margin-top:3px;margin-bottom:10px}
.color-row{display:flex;gap:5px;margin:5px 0 14px;flex-wrap:wrap}
.cswatch{width:24px;height:24px;border-radius:5px;cursor:pointer;border:2px solid transparent}
.cswatch.sel{border-color:#fff}
.type-row{display:flex;gap:4px;margin:5px 0 14px;flex-wrap:wrap}
.tbtn{padding:2px 9px;border-radius:5px;font-size:11px;cursor:pointer}
.mactions{display:flex;gap:8px;justify-content:flex-end}
.btn-p{background:#4a6fa5;color:#fff;border:none;border-radius:6px;padding:7px 18px;cursor:pointer;font-size:13px;font-weight:bold}
.btn-c{background:transparent;color:#aaa;border:1px solid #445;border-radius:6px;padding:7px 14px;cursor:pointer;font-size:13px}
</style>
